# ════════════════════════════════════════════════════════
# Variables d'environnement DOSCO Backend
# Copiez ce fichier en .env et renseignez les valeurs
# ════════════════════════════════════════════════════════

# OBLIGATOIRE — secret de signature des jetons (générez-en un fort !)
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Port d'écoute (Railway/Render/Fly le fournissent automatiquement)
PORT=8080

# ── PERSISTANCE ──
# Option A : PostgreSQL (recommandé en production)
# Railway/Render fournissent cette URL en 1 clic via leur add-on Postgres
DATABASE_URL=
# Mettre 'false' uniquement si votre Postgres local n'utilise pas SSL
PGSSL=true
# Option B : si DATABASE_URL est vide, stockage fichier dans ce dossier
DATA_DIR=./data

# ── IAP (achats intégrés) — optionnel, pour la production mobile ──
APPLE_SHARED_SECRET=
GOOGLE_SERVICE_ACCOUNT_JSON=
